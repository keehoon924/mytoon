// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum TransactionReason {
  SIGNUP
  PURCHASE
  GENERATION
  ADMIN
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  creditBalance   Int       @default(50)
  role            Role      @default(USER)
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  creditTransactions CreditTransaction[]
  emailTokens        EmailToken[]
  characters         Character[]
  projects           Project[]
}


model CreditTransaction {
  id        String            @id @default(cuid())
  userId    String
  delta     Int
  reason    TransactionReason
  createdAt DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum CharacterSourceType {
  PHOTO
  TEXT
  PRESET
}

model Character {
  id                String              @id @default(cuid())
  userId            String
  name              String
  sourceType        CharacterSourceType
  referenceImageUrl String?
  descriptionPrompt String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PresetCharacter {
  id                String   @id @default(cuid())
  name              String
  referenceImageUrl String
  descriptionPrompt String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Project {
  id         String   @id @default(cuid())
  userId     String
  title      String
  cutCount   Int
  layoutType String
  status     String   @default("draft")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cuts     Cut[]
  versions ProjectVersion[]
}

model Cut {
  id               String   @id @default(cuid())
  projectId        String
  orderIndex       Int
  imageUrl         String?
  previousImageUrl String?
  prompt           String?
  characterIds     String[]
  overlayJson      Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bubbles Bubble[]
}

model Bubble {
  id        String   @id @default(cuid())
  cutId     String
  type      String   @default("speech")
  text      String
  font      String   @default("default")
  x         Float    @default(0)
  y         Float    @default(0)
  w         Float    @default(200)
  h         Float    @default(80)
  createdAt DateTime @default(now())

  cut Cut @relation(fields: [cutId], references: [id], onDelete: Cascade)
}

model ProjectVersion {
  id           String   @id @default(cuid())
  projectId    String
  snapshotJson Json
  createdAt    DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model EmailToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  type      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
