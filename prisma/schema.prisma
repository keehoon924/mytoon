// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum TransactionReason {
  SIGNUP
  PURCHASE
  GENERATION
  ADMIN
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  creditBalance   Int       @default(50)
  role            Role      @default(USER)
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  creditTransactions CreditTransaction[]
  emailTokens        EmailToken[]
  characters         Character[]
  projects           Project[]
  folders            Folder[]
  paymentOrders      PaymentOrder[]
  reportsFiled       Report[] @relation("ReportReporter")
  reportsResolved    Report[] @relation("ReportResolver")
}

model Folder {
  id        String   @id @default(cuid())
  userId    String
  name      String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   Folder?   @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Folder[]  @relation("FolderTree")
  projects Project[]

  @@index([userId])
  @@index([parentId])
}


model CreditTransaction {
  id        String            @id @default(cuid())
  userId    String
  delta     Int
  reason    TransactionReason
  createdAt DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum CharacterSourceType {
  PHOTO
  TEXT
  PRESET
}

model Character {
  id                String              @id @default(cuid())
  userId            String
  name              String
  sourceType        CharacterSourceType
  referenceImageUrl String?
  descriptionPrompt String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PresetCharacter {
  id                String   @id @default(cuid())
  name              String
  referenceImageUrl String
  descriptionPrompt String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Project {
  id         String   @id @default(cuid())
  userId     String
  folderId   String?
  title      String
  cutCount   Int
  layoutType String
  status     String   @default("draft")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder   Folder?          @relation(fields: [folderId], references: [id], onDelete: SetNull)
  cuts     Cut[]
  versions ProjectVersion[]

  @@index([folderId])
}

model Cut {
  id               String   @id @default(cuid())
  projectId        String
  orderIndex       Int
  imageUrl         String?
  previousImageUrl String?
  prompt           String?
  characterIds     String[]
  overlayJson      Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bubbles Bubble[]
}

model Bubble {
  id        String   @id @default(cuid())
  cutId     String
  type      String   @default("speech")
  text      String
  font      String   @default("default")
  color     String   @default("#111111")
  fontSize  Int      @default(14)
  bold      Boolean  @default(false)
  x         Float    @default(0)
  y         Float    @default(0)
  w         Float    @default(200)
  h         Float    @default(80)
  rotation  Float    @default(0)
  zIndex    Int      @default(0)
  createdAt DateTime @default(now())

  cut Cut @relation(fields: [cutId], references: [id], onDelete: Cascade)
}

enum ReportTargetType {
  PROJECT
  CHARACTER
}

enum ReportReason {
  SPAM
  ADULT
  VIOLENCE
  COPYRIGHT
  OTHER
}

enum ReportStatus {
  PENDING
  RESOLVED_DELETED
  RESOLVED_DISMISSED
  RESOLVED_HOLD
}

model Report {
  id           String           @id @default(cuid())
  reporterId   String
  targetType   ReportTargetType
  targetId     String
  reason       ReportReason
  detail       String?
  status       ReportStatus     @default(PENDING)
  resolvedById String?
  resolvedAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  reporter   User  @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  resolvedBy User? @relation("ReportResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@unique([reporterId, targetType, targetId])
  @@index([status])
  @@index([targetType, targetId])
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELED
}

model PaymentOrder {
  id              String        @id @default(cuid())
  userId          String
  packageId       String
  credits         Int
  amountKrw       Int
  status          PaymentStatus @default(PENDING)
  tossOrderId     String        @unique
  tossPaymentKey  String?
  failReason      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ProjectVersion {
  id           String   @id @default(cuid())
  projectId    String
  snapshotJson Json
  createdAt    DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model EmailToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  type      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
